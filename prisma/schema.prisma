// Prisma schema for agrozakaz-test
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageKey    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  schemas     Schema[]
  products    Product[]  @relation("CategoryProducts")
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@map("categories")
}

model Schema {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageKey    String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  markers     PartMarker[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@map("schemas")
}

model PartMarker {
  id        String   @id @default(cuid())
  schemaId  String
  schema    Schema   @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  position  Int
  label     String?
  x         Float
  y         Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schemaId])
  @@index([productId])
  @@map("part_markers")
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  priceRub    Int
  stockCount  Int      @default(0)
  imageKey    String?
  warehouseId String?
  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  categories  Category[]   @relation("CategoryProducts")
  markers     PartMarker[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([warehouseId])
  @@map("products")
}

model Warehouse {
  id        String    @id @default(cuid())
  name      String
  city      String?
  address   String?
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("warehouses")
}
